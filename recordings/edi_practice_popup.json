{
    "title": "練習EDI 検収照会（カレンダーのポップアップで月選択する版）",
    "steps": [
        { "type": "setViewport", "width": 1250, "height": 1000 },
        { "type": "navigate", "url": "http://localhost:8000/edi/index.html" },
        {
            "type": "change",
            "value": "{{SECRET:MY_USERNAME}}",
            "target": "main",
            "selectors": [["#username"], ["xpath///*[@id=\"username\"]"]]
        },
        {
            "type": "change",
            "value": "{{SECRET:MY_PASSWORD}}",
            "target": "main",
            "selectors": [["#password"], ["xpath///*[@id=\"password\"]"]]
        },
        {
            "type": "click",
            "target": "main",
            "selectors": [["#loginBtn"], ["aria/Login"], ["text/Login"]]
        },
        {
            "type": "click",
            "target": "main",
            "frame": [0],
            "selectors": [["#linkKenshu"], ["text/検収照会"], ["aria/検収照会"]]
        },
        {
            "type": "click",
            "target": "main",
            "frame": [2],
            "selectors": [["#refBtn"], ["text/参照"]]
        },
        {
            "type": "click",
            "target": "http://localhost:8000/edi/calendar.html",
            "selectors": [["#m05"], ["text/05月"], ["aria/05月"]]
        },
        {
            "type": "click",
            "target": "main",
            "frame": [2],
            "selectors": [["#searchBtn"], ["text/検 索"]]
        }
    ]
}
